{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {
      llm_api_key: { type: "string", secret: true },
    },
    required: ["llm_api_key"],
    additionalProperties: false,
  },

  slots: {
    proxy: { kind: "a2a", optional: true },
  },

  program: {
    image: "ghcr.io/ddreamboy/tau2-purple-agent:latest",
    entrypoint: "uv run python src/server.py --host 0.0.0.0 --port 9009",

    env: {
      LLM_API_URL: "https://routerai.ru/api/v1",
      LLM_API_KEY: "${config.llm_api_key}",
      LLM_API_BASE_MODEL: "google/gemini-2.5-flash-lite",
    },

    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9009 },
      ],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },

  metadata: {
    assessment_config: {},
    participant_roles: [],
  },
}
